{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "lib": ["es2017", "dom"],
    "esModuleInterop": true,
    "jsx": "react-native",
    "skipLibCheck": true,
    "moduleResolution": "bundler"
  },
  "include": ["index.ts", "App.tsx", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["app", "backend", "developer-portal", "sdks", "contracts", "chaos"]
}
