{
  "expo": {
    "name": "SubTrackr",
    "slug": "subtrackr",
    "version": "1.0.0",
    "scheme": "subtrackr",
    "orientation": "portrait",
    "icon": "./assets/subtrackr-icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/subtrackr-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.subtrackr.app",
      "icon": "./assets/subtrackr-icon.png",
      "associatedDomains": ["applinks:subtrackr.app"]
    },
    "android": {
      "package": "com.subtrackr.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/subtrackr-icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "edgeToEdgeEnabled": true,
      "icon": "./assets/subtrackr-icon.png",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "subtrackr.app",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "jsEngine": "hermes",
      "hermesFlags": ["-g", "--minify", "--inline-store-on-put", "--allocation-profile"]
    },
    "web": {
      "favicon": "./assets/subtrackr-icon.png",
      "name": "SubTrackr - Subscription Management with Crypto Payments",
      "description": "Manage your subscriptions with Web3 crypto payments"
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    },
    "owner": "subtrackr",
    "description": "Subscription Management with Crypto Payments",
    "keywords": ["subscription", "crypto", "web3", "blockchain", "payments"],
    "primaryColor": "#6366f1",
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": [],
          "enableBackgroundRemoteNotifications": false
        }
      ],
      "@config-plugins/detox"
    ]
  }
}
